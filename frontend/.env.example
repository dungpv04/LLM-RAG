# Backend URL for Vite dev server proxy
# Used by vite.config.js to configure proxy target for /chat, /documents, /rag routes
# Default: http://localhost:8009 (matches docker-compose backend port mapping)
VITE_BACKEND_URL=http://localhost:8009

# API URL for production builds
# Leave empty when using Vite dev server proxy (development mode)
# Set to your production API URL when building for production
# Example: https://api.pdp8.production.com
VITE_API_URL=
