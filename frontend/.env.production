# Production Environment Configuration Template
# Copy this file and customize for your production deployment
# Rename to .env.production.local for local production testing

# Backend URL (not used in production builds, but kept for consistency)
VITE_BACKEND_URL=https://api.pdp8.production.com

# API URL - MUST be set for production builds
# This value gets embedded into the production JavaScript bundle
VITE_API_URL=https://api.pdp8.production.com
